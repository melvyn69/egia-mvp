{
  "name": "egia-mvp",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "dev:fixed": "vite --port 5173 --strictPort",
    "build:shared": "tsc -p server/_shared/tsconfig.shared.json",
    "build:server": "npm run build:shared && tsc -p tsconfig.server.json",
    "clean:weirdfiles": "node scripts/clean-weirdfiles.js",
    "build": "tsc -b && npm run build:server && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "node scripts/test-egress-guardrails.mjs",
    "test:production-security": "tsx scripts/test-production-security.ts",
    "test:goal-006": "node scripts/test-goal-006-claim-ai-tag-candidates.mjs",
    "test:goal-007:internal-key": "tsx scripts/test-goal-007-internal-api-key.ts",
    "test:goal-007:db-channel": "node scripts/test-goal-007-db-channel.mjs",
    "test:goal-007:provisioner": "node scripts/test-goal-007-secret-provisioner.mjs",
    "test:goal-007:apple-wallet": "node scripts/test-goal-007-apple-wallet.mjs",
    "test:goal-007:synth": "node scripts/test-goal-007-synth-runner.mjs",
    "test:goal-007:postdeploy-probes": "node scripts/test-goal-007-postdeploy-probes.mjs",
    "test:goal-007:synthetic-rate-limit": "tsx scripts/test-goal-007-synthetic-rate-limit.ts",
    "test:goal-007": "npm run test:goal-007:internal-key && npm run test:goal-007:db-channel && npm run test:goal-007:provisioner && npm run test:goal-007:apple-wallet && npm run test:goal-007:synth && npm run test:goal-007:postdeploy-probes && npm run test:goal-007:synthetic-rate-limit",
    "test:edge-types": "npx --yes deno@2.9.2 check --config=supabase/functions/deno.json --frozen supabase/functions/generate-reply/index.ts supabase/functions/google_gbp_sync_all/index.ts supabase/functions/google_gbp_sync_locations/index.ts supabase/functions/google_oauth_exchange/index.ts supabase/functions/google_oauth_start/index.ts supabase/functions/post-reply-google/index.ts supabase/functions/process-review-analyze/index.ts",
    "test:migration-history": "node scripts/validate-supabase-migration-history.mjs",
    "test:migration-history:adversarial": "node scripts/test-supabase-migration-history-validator.mjs",
    "test:canonical-bootstrap-plan": "node scripts/plan-goal-005-canonical-bootstrap.mjs",
    "test:canonical-bootstrap": "bash scripts/bootstrap-goal-005-canonical.sh --plan-only",
    "test:canonical-bootstrap:guards": "node scripts/test-goal-005-bootstrap-guardrails.mjs",
    "smoke": "tsx scripts/smoke-api.ts",
    "test:google-connection-status": "tsc --target ES2022 --module CommonJS --moduleResolution node --outDir .tmp-tests scripts/test-google-connection-status.ts && node .tmp-tests/scripts/test-google-connection-status.js",
    "test:google-connection-status:clean": "rm -rf .tmp-tests",
    "smoke:google-onboarding": "tsx scripts/smoke-google-onboarding.ts",
    "preview": "vite preview",
    "sync:db-types": "cp src/database.types.ts server/_shared/database.types.ts",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "test:goal-007:synth:local": "node scripts/goal002-synth.mjs",
    "pdf:smoke": "tsx scripts/pdf-smoke.ts",
    "smoke:reports": "tsx scripts/smoke-reports-html.ts"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.62.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.541.0",
    "passkit-generator": "^3.5.7",
    "pdf-lib": "^1.17.1",
    "pg": "8.22.0",
    "puppeteer-core": "^22.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.2",
    "tailwind-merge": "^3.4.0",
    "yauzl": "2.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/react-query-devtools": "^5.62.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.5.16",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "overrides": {
    "@vercel/static-config": {
      "ajv": "^8.18.0"
    },
    "joi": "^17.13.4",
    "js-yaml": "^4.1.2",
    "minimatch": "^10.2.3",
    "path-to-regexp": "^6.3.0",
    "smol-toml": "^1.6.1",
    "undici": "^6.27.0"
  }
}
