{
  "version": 2,
  "routes": [
    {
      "src": "/api/cron/(.*)",
      "dest": "/api/cron/[...slug]?slug=$1"
    },
    {
      "src": "/api/google/(.*)",
      "dest": "/api/google/[...slug]?slug=$1"
    },
    { "handle": "filesystem" },
    { "src": "/(?!api/).*", "dest": "/index.html" }
  ]
}
